<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="HamNetProgrammer.Desktop.Views.HealthCheckPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#10161d">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Health Check" FontSize="22" FontWeight="Bold" Foreground="#e0924a" Margin="0,0,0,12" />

        <Border Grid.Row="1" Background="#1a232c" CornerRadius="6" Padding="14" Margin="0,0,0,12">
            <StackPanel Spacing="8">
                <TextBlock FontSize="12" Foreground="#8896a0" TextWrapping="Wrap"
                           Text="Checks the current codeplug database for a small set of high-confidence issues: channels that look like leftover duplicates of another (same name/frequency/colour code/timeslot under a different channel number), scan lists or group lists that have drifted from their same-named zone's membership, and duplicate talkgroup contacts. A good first step after Read Codeplug, or any time before writing to the radio. Doesn't check anything not listed here yet - it grows as real issues turn up." />
                <Button x:Name="RunButton" Content="Run Health Check" Click="OnRunClicked" Background="#e0924a" Foreground="#10161d" FontWeight="SemiBold" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#1a232c" CornerRadius="6">
            <ScrollViewer Padding="14">
                <TextBlock x:Name="ResultsText" FontFamily="Consolas" FontSize="12" Foreground="#dce6ea" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                           Text="Click Run Health Check to scan the current database." />
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
