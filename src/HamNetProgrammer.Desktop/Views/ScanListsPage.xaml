<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="HamNetProgrammer.Desktop.Views.ScanListsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#10161d">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <TextBlock Text="Scan Lists" FontSize="22" FontWeight="Bold" Foreground="#e0924a" VerticalAlignment="Center" />
            <TextBlock x:Name="SummaryText" FontSize="12" Foreground="#8896a0" VerticalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1a232c" CornerRadius="6">
                    <ListView x:Name="ScanListListView" SelectionChanged="OnSelectionChanged" Padding="4">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Consolas" Padding="8,6" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                    <Button x:Name="NewButton" Content="New" Click="OnNewClicked" ToolTipService.ToolTip="New scan list" />
                    <Button x:Name="RenameButton" Content="Rename" Click="OnRenameClicked" ToolTipService.ToolTip="Rename selected scan list" />
                    <Button x:Name="DeleteButton" Content="Delete" Click="OnDeleteClicked" ToolTipService.ToolTip="Delete selected scan list" />
                </StackPanel>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                    <Button x:Name="AddChannelButton" Content="Add Channel..." Click="OnAddChannelClicked" />
                    <Button x:Name="SettingsButton" Content="Settings..." Click="OnSettingsClicked"
                            ToolTipService.ToolTip="Priority channels, look-back, dropout and dwell timing, revert channel" />
                </StackPanel>

                <Border Grid.Row="1" Background="#1a232c" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Background="#212c36" Padding="10,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="#" FontSize="11" Foreground="#8896a0" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="Channel" FontSize="11" Foreground="#8896a0" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="MHz" FontSize="11" Foreground="#8896a0" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="" FontSize="11" Foreground="#8896a0" FontWeight="SemiBold" />
                        </Grid>

                        <ListView x:Name="MemberListView" Grid.Row="1" Padding="4" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="10,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="140" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Position}" FontFamily="Consolas" FontSize="12" Foreground="#8896a0" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" Foreground="#dce6ea" />
                                        <TextBlock Grid.Column="2" Text="{Binding FrequencyMHz}" FontFamily="Consolas" FontSize="12" Foreground="#dce6ea" />
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                                            <Button Content="Up" FontSize="10" Padding="6,2" Tag="{Binding Position}" Click="OnMoveUpClicked" />
                                            <Button Content="Down" FontSize="10" Padding="6,2" Tag="{Binding Position}" Click="OnMoveDownClicked" />
                                            <Button Content="Remove" FontSize="10" Padding="6,2" Tag="{Binding Position}" Click="OnRemoveChannelClicked" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
