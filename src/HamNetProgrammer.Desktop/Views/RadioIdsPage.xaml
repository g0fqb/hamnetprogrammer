<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="HamNetProgrammer.Desktop.Views.RadioIdsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#10161d">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <TextBlock Text="Radio IDs" FontSize="22" FontWeight="Bold" Foreground="#e0924a" VerticalAlignment="Center" />
            <TextBlock x:Name="SummaryText" FontSize="12" Foreground="#8896a0" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
            <Button x:Name="NewButton" Content="New Radio ID..." Click="OnNewClicked"
                    ToolTipService.ToolTip="Add a callsign + DMR ID, either typed in or looked up from radioid.net" />
        </StackPanel>

        <Border Grid.Row="2" Background="#1a232c" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#212c36" Padding="10,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Callsign" FontSize="11" Foreground="#8896a0" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="DMR ID" FontSize="11" Foreground="#8896a0" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="2" Text="" FontSize="11" Foreground="#8896a0" FontWeight="SemiBold" />
                </Grid>

                <ListView x:Name="RadioIdListView" Grid.Row="1" Padding="4" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="10,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Callsign}" FontFamily="Consolas" FontSize="12" Foreground="#dce6ea"
                                           TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Callsign}" />
                                <TextBlock Grid.Column="1" Text="{Binding DmrIdDisplay}" FontFamily="Consolas" FontSize="12" Foreground="#dce6ea" />
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                                    <Button Content="Edit" FontSize="11" Padding="8,3" Tag="{Binding Id}" Click="OnEditClicked" />
                                    <Button Content="Delete" FontSize="11" Padding="8,3" Tag="{Binding Id}" Click="OnDeleteClicked" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
