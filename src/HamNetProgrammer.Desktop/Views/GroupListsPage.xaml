<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="HamNetProgrammer.Desktop.Views.GroupListsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#10161d">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <TextBlock Text="Group Lists" FontSize="22" FontWeight="Bold" Foreground="#e0924a" VerticalAlignment="Center" />
            <TextBlock x:Name="SummaryText" FontSize="12" Foreground="#8896a0" VerticalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1a232c" CornerRadius="6" Margin="0,0,10,0">
                <ListView x:Name="GroupListListView" SelectionChanged="OnSelectionChanged" Padding="4">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" FontFamily="Consolas" Padding="8,6" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <Border Grid.Column="1" Background="#1a232c" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="#212c36" Padding="10,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" FontSize="11" Foreground="#8896a0" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="Contact" FontSize="11" Foreground="#8896a0" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="2" Text="Type" FontSize="11" Foreground="#8896a0" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="3" Text="DMR ID" FontSize="11" Foreground="#8896a0" FontWeight="SemiBold" />
                    </Grid>

                    <ListView x:Name="MemberListView" Grid.Row="1" Padding="4" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="10,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Position}" FontFamily="Consolas" FontSize="12" Foreground="#8896a0" />
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" Foreground="#dce6ea" />
                                    <TextBlock Grid.Column="2" Text="{Binding CallType}" FontSize="12" Foreground="#8896a0" />
                                    <TextBlock Grid.Column="3" Text="{Binding DmrId}" FontFamily="Consolas" FontSize="12" Foreground="#dce6ea" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
