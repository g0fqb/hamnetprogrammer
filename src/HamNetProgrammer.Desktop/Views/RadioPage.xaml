<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="HamNetProgrammer.Desktop.Views.RadioPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#10161d">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Radio" FontSize="22" FontWeight="Bold" Foreground="#e0924a" Margin="0,0,0,12" />

        <!-- Header and status bar (below) are Auto-height siblings of this row, so they always get
             their natural space reserved first and stay visible regardless of window size - this
             row is what shrinks/scrolls on a short window, never the status bar carrying live
             progress feedback. Confirmed the hard way: without this, the status bar could be
             pushed clean off the bottom of a window shorter than the page's natural content. -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" MaxHeight="620" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Two columns instead of one long stack - roughly halves the vertical space these
                 six cards need, so more of a short/low-res window is left for the log below. Capped
                 at 400px and independently scrollable past that, as a safety net for anything
                 shorter still. -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid ColumnSpacing="12" Padding="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="12">
                        <Border Background="#1a232c" CornerRadius="6" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Connection" FontSize="14" FontWeight="SemiBold" Foreground="#dce6ea" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ComboBox x:Name="PortComboBox" Width="140" PlaceholderText="Select port" SelectionChanged="OnPortSelectionChanged" />
                                    <Button x:Name="RefreshButton" Content="Refresh" Click="OnRefreshClicked" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="AutoDetectButton" Content="Auto-Detect Radio" Click="OnAutoDetectClicked"
                                            ToolTipService.ToolTip="Tries each free serial port for the AT-D878UV's handshake response. Ports already open in another program are skipped." />
                                    <Button x:Name="TestConnectionButton" Content="Test Connection" Click="OnTestConnectionClicked" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- High-Level group: the decoded, editable codeplug database (Zones/
                             Channels/Contacts/Lists) - what you actually work with in this app. Left
                             border accent (teal) distinguishes it at a glance from the Low-Level
                             group's raw-byte operations opposite it, so the two are never mistaken
                             for a matched pair the way "Backup"/"Restore Previous" used to read. -->
                        <Border Background="#152025" BorderBrush="#6bb0b8" BorderThickness="0,0,0,2" CornerRadius="6" Padding="14,10,14,14">
                            <StackPanel Spacing="10">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Codeplug Database - High-Level" FontSize="13" FontWeight="Bold" Foreground="#6bb0b8" />
                                    <TextBlock FontSize="11" Foreground="#8896a0" TextWrapping="Wrap"
                                               Text="Decoded zones/channels/contacts/lists - what you edit elsewhere in this app. These operations translate between that database and the radio." />
                                </StackPanel>

                                <Border Background="#1a232c" CornerRadius="6" Padding="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Write codeplug to radio" FontSize="14" FontWeight="SemiBold" Foreground="#dce6ea" />
                                        <TextBlock FontSize="12" Foreground="#8896a0" TextWrapping="Wrap"
                                                   Text="Encodes the current SQLite codeplug and writes it to the radio across several programming sessions. The radio will restart itself several times during this - that's expected, not an error - and returns to normal once it finishes." />
                                        <Button x:Name="WriteCodeplugButton" Content="Write Codeplug to Radio" Click="OnWriteCodeplugClicked" Background="#e0924a" Foreground="#10161d" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#1a232c" CornerRadius="6" Padding="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Read codeplug from radio" FontSize="14" FontWeight="SemiBold" Foreground="#dce6ea" />
                                        <TextBlock FontSize="12" Foreground="#8896a0" TextWrapping="Wrap"
                                                   Text="Reads the radio (safe, same as Backup) and brings its zones/channels/contacts/lists into this database - a good first step if your radio is already set up. New items are added; items already here that match by name or channel number get their details and membership refreshed to match the radio. Nothing already in the database is deleted, so this is safe to run again later or from a second radio sharing the same codeplug. Only available for a hardware-verified radio model." />
                                        <Button x:Name="ReadCodeplugButton" Content="Read Codeplug from Radio" Click="OnReadCodeplugClicked" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#1a232c" CornerRadius="6" Padding="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Restore previous codeplug" FontSize="14" FontWeight="SemiBold" Foreground="#dce6ea" />
                                        <TextBlock FontSize="12" Foreground="#8896a0" TextWrapping="Wrap"
                                                   Text="Pick from any past Write Codeplug run and write back exactly what it overwrote, from the automatic backup taken just before it - a way to back out if something looks wrong, even days later. If that write never actually reached the radio, this instead takes a fresh dump and proves the radio still matches the pre-write backup, rather than just assuming it." />
                                        <Button x:Name="RestoreButton" Content="Restore Previous Codeplug" Click="OnRestoreClicked" IsEnabled="False" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#1a232c" CornerRadius="6" Padding="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Sync reference data" FontSize="14" FontWeight="SemiBold" Foreground="#dce6ea" />
                                        <TextBlock FontSize="12" Foreground="#8896a0" TextWrapping="Wrap"
                                                   Text="Writes your talkgroup list and the full radioid.net individual-callsign database (for caller ID on people you haven't added yourself) to the radio. This is separate from Write Codeplug because it rarely changes and takes far longer to upload - run it every few weeks, not after every small edit." />
                                        <Button x:Name="SyncReferenceDataButton" Content="Sync Reference Data" Click="OnSyncReferenceDataClicked" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="12">
                        <!-- Low-Level group: exact bytes, model-specific, no understanding of what
                             they mean - the raw-memory counterpart to the High-Level group opposite.
                             Backup Radio Memory and Restore Radio Memory are the actual matched pair
                             here (Restore Previous Codeplug, despite the name, is a Write Codeplug
                             feature - it lives in the other group). Amber accent (matches the
                             app's primary/warning colour) to read as "handle with care - raw bytes,
                             not the friendly editable database". -->
                        <Border Background="#221a12" BorderBrush="#e0924a" BorderThickness="0,0,0,2" CornerRadius="6" Padding="14,10,14,14">
                            <StackPanel Spacing="10">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Raw Memory - Low-Level" FontSize="13" FontWeight="Bold" Foreground="#e0924a" />
                                    <TextBlock FontSize="11" Foreground="#8896a0" TextWrapping="Wrap"
                                               Text="Exact radio bytes, for backup/recovery or extending support to other models - not decoded into the codeplug database above." />
                                </StackPanel>

                                <Border Background="#1a232c" CornerRadius="6" Padding="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Backup radio memory" FontSize="14" FontWeight="SemiBold" Foreground="#dce6ea" />
                                        <TextBlock FontSize="12" Foreground="#8896a0" TextWrapping="Wrap"
                                                   Text="Reads every known memory region from the radio to a timestamped .bin + .manifest.csv pair in the dumps folder. Safe, read-only. Pairs with Restore Radio Memory below, which can write one of these files back." />
                                        <Button x:Name="BackupButton" Content="Backup Radio Memory" Click="OnBackupClicked" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#1a232c" CornerRadius="6" Padding="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Restore radio memory" FontSize="14" FontWeight="SemiBold" Foreground="#dce6ea" />
                                        <TextBlock FontSize="12" Foreground="#8896a0" TextWrapping="Wrap"
                                                   Text="Pick any past .bin memory dump (from Backup Radio Memory, or another diagnostics session) and write its ENTIRE contents back to the radio, overwriting everything currently there. A safety backup of the radio's current state is taken automatically first. Only available for a hardware-verified radio model." />
                                        <Button x:Name="RestoreRadioMemoryButton" Content="Restore Radio Memory" Click="OnRestoreRadioMemoryClicked" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#1a232c" CornerRadius="6" Padding="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Contribute a memory-map sample" FontSize="14" FontWeight="SemiBold" Foreground="#dce6ea" />
                                        <TextBlock FontSize="12" Foreground="#8896a0" TextWrapping="Wrap"
                                                   Text="Read-only - never writes anything to the radio. Helps extend support to other AnyTone-family models we don't own by capturing what's actually at each known memory address. Most useful if your radio isn't a D878UV." />
                                        <Button x:Name="ContributeSampleButton" Content="Contribute Memory Sample" Click="OnContributeSampleClicked" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#1a232c" CornerRadius="6" Padding="14">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Diagnostic report" FontSize="14" FontWeight="SemiBold" Foreground="#dce6ea" />
                                        <TextBlock FontSize="12" Foreground="#8896a0" TextWrapping="Wrap"
                                                   Text="Every Write Codeplug or Restore run automatically saves a before/after memory backup and a log of every region written. If something looks wrong - including a failure message that points here - send that report so it can be investigated, no need to attach anything yourself or dig through the log panel." />
                                        <Button x:Name="SendReportButton" Content="Send Diagnostic Report" Click="OnSendReportClicked" IsEnabled="False" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Border Grid.Row="1" Background="#1a232c" CornerRadius="6" Margin="0,14,0,0">
                <ScrollViewer x:Name="LogScrollViewer" Padding="10">
                    <TextBlock x:Name="LogText" FontFamily="Consolas" FontSize="11" Foreground="#dce6ea" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#1a232c" CornerRadius="6" Margin="0,10,0,0" Padding="14,10">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Only shown during Write Codeplug (see OnWriteCodeplugClicked) - a full write
                     legitimately drops the radio off USB and re-enumerates it several times in a
                     row (once per isolated shared-block/channel-bank session, proven necessary on
                     real hardware - see AnyToneD878CodeplugWriter's remarks), which looks alarming
                     to someone who doesn't know that's expected. -->
                <Border x:Name="RebootNoticeBanner" Grid.Row="0" Visibility="Collapsed"
                        Background="#332a16" BorderBrush="#e0924a" BorderThickness="1" CornerRadius="4" Padding="10,7">
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#e0c48a"
                               Text="The radio will restart itself several times during this write - each one is expected, not an error. Please leave it connected and powered on until this finishes." />
                </Border>

                <Grid Grid.Row="1" ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <Ellipse x:Name="ConnectionDot" Width="9" Height="9" Fill="#5a6570" />
                        <TextBlock x:Name="ConnectionStatusText" FontSize="12" Foreground="#dce6ea" Text="Not connected." />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <ProgressBar x:Name="OperationProgressBar" Minimum="0" Maximum="1" Value="0" />
                        <TextBlock x:Name="OperationStatusText" FontSize="12" Foreground="#8896a0" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
