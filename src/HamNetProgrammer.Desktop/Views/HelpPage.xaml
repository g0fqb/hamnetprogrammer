<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="HamNetProgrammer.Desktop.Views.HelpPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#10161d">

    <ScrollViewer>
        <StackPanel Padding="16" Spacing="14" MaxWidth="900">

            <TextBlock Text="Help" FontSize="22" FontWeight="Bold" Foreground="#e0924a" />
            <TextBlock Text="What each screen does." FontSize="12" Foreground="#8896a0" />

            <Border Background="#1a232c" CornerRadius="8" Padding="16" BorderBrush="#ffb74d" BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBlock Text="Support" FontSize="16" FontWeight="Bold" Foreground="#ffb74d" />
                    <TextBlock Foreground="#dddddd" FontSize="13" TextWrapping="Wrap">
                        HamNetProgrammer is a free, open-source codeplug tool for the AnyTone
                        AT-D878UV, built to fix the real problems in the vendor tools: CPS's
                        Zones and Scan Lists silently break on every CSV reimport, and RT
                        Systems runs out of memory importing a full talkgroup database. If it's
                        useful to you, the Support button funds continued development.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="#1a232c" CornerRadius="8" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Text="Zones" FontSize="15" FontWeight="Bold" Foreground="#dce6ea" />
                    <TextBlock Foreground="#aabbc4" FontSize="13" TextWrapping="Wrap">
                        Browse zones and the channels in each one, imported from your SQLite
                        codeplug database. Scan lists, group lists, and roaming zones are built
                        automatically from this zone structure.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="#1a232c" CornerRadius="8" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Text="Radio" FontSize="15" FontWeight="Bold" Foreground="#dce6ea" />
                    <TextBlock Foreground="#aabbc4" FontSize="13" TextWrapping="Wrap">
                        Connects to the AT-D878UV over its USB programming cable. Reading and
                        writing the codeplug itself is currently done via the command-line tool
                        (dump / encode / write-codeplug) - a full connected view is planned here.
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
