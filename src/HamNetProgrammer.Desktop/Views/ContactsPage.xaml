<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="HamNetProgrammer.Desktop.Views.ContactsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#10161d">

    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
            <TextBlock Text="Digital Contacts" FontSize="22" FontWeight="Bold" Foreground="#e0924a" VerticalAlignment="Center" />
            <TextBlock x:Name="SummaryText" FontSize="12" Foreground="#8896a0" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="1" Spacing="12" MaxWidth="900" HorizontalAlignment="Left">
            <Border Background="#1a232c" CornerRadius="6" Padding="14">
                <StackPanel Spacing="8">
                    <TextBlock Text="Import talkgroups" FontSize="14" FontWeight="SemiBold" Foreground="#dce6ea" />
                    <TextBlock FontSize="12" Foreground="#8896a0" TextWrapping="Wrap"
                               Text="Pulls the shared talkgroup list (Brandmeister, TGIF, and FreeDMR merged and deduped by number) from our backend, so every install uses the same reference. Network is recorded only as where each contact's data came from." />
                    <Button x:Name="ImportButton" Content="Import Talkgroups" Click="OnImportClicked" HorizontalAlignment="Left" />
                    <TextBlock x:Name="ImportStatusText" FontSize="12" Foreground="#6bb0b8" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Background="#1a232c" CornerRadius="6" Padding="14">
                <StackPanel Spacing="8">
                    <TextBlock Text="Search" FontSize="14" FontWeight="SemiBold" Foreground="#dce6ea" />
                    <TextBox x:Name="SearchBox" PlaceholderText="Type a name or talkgroup number..." TextChanged="OnSearchTextChanged" />
                </StackPanel>
            </Border>
        </StackPanel>

        <Border Grid.Row="2" Background="#1a232c" CornerRadius="6" Margin="0,14,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#212c36" Padding="10,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Name" FontSize="11" Foreground="#8896a0" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="1" Text="DMR ID" FontSize="11" Foreground="#8896a0" FontWeight="SemiBold" />
                    <TextBlock Grid.Column="2" Text="Network" FontSize="11" Foreground="#8896a0" FontWeight="SemiBold" />
                </Grid>

                <ListView x:Name="ResultsListView" Grid.Row="1" Padding="4" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="10,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="12" Foreground="#dce6ea"
                                           TextTrimming="CharacterEllipsis" ToolTipService.ToolTip="{Binding Name}" />
                                <TextBlock Grid.Column="1" Text="{Binding DmrIdDisplay}" FontFamily="Consolas" FontSize="12" Foreground="#dce6ea" />
                                <TextBlock Grid.Column="2" Text="{Binding NetworkDisplay}" FontSize="12" Foreground="#8896a0" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>
